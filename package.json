{
  "name": "@postcept/relay",
  "version": "0.3.0",
  "description": "Customer-side relay for Postcept. Reads your system of record with credentials that never leave your environment, signs what it saw as an observation envelope, and submits it for verification. Postcept judges completion without holding your provider keys.",
  "license": "MIT",
  "author": "Postcept",
  "keywords": [
    "postcept",
    "relay",
    "proof-of-completion",
    "ai-agents",
    "verification",
    "stripe"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Postcept/relay.git"
  },
  "homepage": "https://postcept.com",
  "bugs": "https://github.com/Postcept/relay/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "postcept-relay": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "deploy"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3"
  }
}
